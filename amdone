        if SFind(tostring(Key),"Enum") then
            Keybind.Key=tostring(Key); local kname=Key.Name=="Backspace" and "None" or Key.Name
            local ks=Keys[Keybind.Key] or SGSub(kname,"Enum.","") or "None"
            local td=SGSub(SGSub(ks,"KeyCode.",""),"UserInputType.","")
            Keybind.Value=td; Items["KeyButton"].Instance.Text="[ "..td.." ]"
            Library.Flags[Keybind.Flag]={Mode=Keybind.Mode,Key=Keybind.Key,Toggled=Keybind.Toggled,active=Keybind.Toggled}
            if Data.Callback then Library:SafeCall(Data.Callback,Keybind.Toggled) end; Update()
        elseif type(Key)=="table" then
            local rk=Key.Key=="Backspace" and "None" or Key.Key; Keybind.Key=tostring(Key.Key)
            Keybind.Mode=Key.Mode or "Toggle"; Keybind:SetMode(Keybind.Mode)
            local ks=Keys[Keybind.Key] or SGSub(tostring(rk),"Enum.","") or rk
            local td=SGSub(SGSub(ks,"KeyCode.",""),"UserInputType.","")
            Keybind.Value=td; Items["KeyButton"].Instance.Text="[ "..td.." ]"
            if Key.Toggled then Keybind:Press(Key.Toggled,true) end
            if Data.Callback then Library:SafeCall(Data.Callback,Keybind.Toggled) end; Update()
        elseif TFind({"Toggle","Hold","Always"},Key) then
