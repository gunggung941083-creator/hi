        Colorpicker.Value=Clamp(1-(Input.Position.Y-px.Y)/ps.Y,0,1)
        local dx=Clamp((Input.Position.X-px.X)/ps.X,0,0.99); local dy=Clamp((Input.Position.Y-px.Y)/ps.Y,0,0.99)
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.08,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(dx,0,dy,0)})
        Colorpicker:Update()
    end
    function Colorpicker:SlideHue(Input)
        if not Input or not SlidingHue then return end
        local hp=Items["Hue"].Instance.AbsolutePosition; local hs=Items["Hue"].Instance.AbsoluteSize
        Colorpicker.Hue=Clamp((Input.Position.Y-hp.Y)/hs.Y,0,1)
        Items["HueDragger"]:Tween(TweenInfo.new(0.08,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(0,0,Clamp((Input.Position.Y-hp.Y)/hs.Y,0,0.99),0)})
