                if not Debounce then Window:SetOpen(not Window.IsOpen) end
            end
        end)
    end
    Window:SetCenter(); task.wait()
    Window.IsOpen=true; Items["MainFrame"].Instance.Visible=true
    Items["MainFrame"].Instance.Size=U2(0,WW,0,WH); Items["MainFrame"].Instance.BackgroundTransparency=0
    Library:CreateMobileToggle(Window)
    return setmetatable(Window,Library)
