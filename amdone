    function Textbox:SetVisibility(Bool) Items["Row"].Instance.Visible=Bool end
    function Textbox:Set(Value)
        if Textbox.Numeric then if (not tonumber(Value)) and SLen(tostring(Value))>0 then Value=Textbox.Value end end
        Textbox.Value=Value; Items["Input"].Instance.Text=Value; Library.Flags[Textbox.Flag]=Value
        if Textbox.Callback then Library:SafeCall(Textbox.Callback,Textbox.Value) end
    end
    if Textbox.Finished then
        Items["Input"]:Connect("FocusLost",function(enter) if enter then Textbox:Set(Items["Input"].Instance.Text) end end)
    else
        Items["Input"].Instance:GetPropertyChangedSignal("Text"):Connect(function() Textbox:Set(Items["Input"].Instance.Text) end)
    end
    if Textbox.Default then Textbox:Set(Textbox.Default) end
    Library.SetFlags[Textbox.Flag]=function(v) Textbox:Set(v) end
    return Textbox
end

Library.CreateSettingsPage = function(self, Window, KeybindList, Watermark, ModeratorList)
    local cols=IsMobile and 1 or 2
    local SP=Window:Page({Name="Settings",Columns=cols})
    local side1=1; local side2=IsMobile and 1 or 2
    local SS=SP:Section({Name="Settings",Side=side1})
    SS:Button({Name="Unload",Callback=function() Library:Unload() end})
    SS:Toggle({Name="Watermark",Flag="Watermark",Default=true,Callback=function(v) if Watermark then Watermark:SetVisibility(v) end end})
    SS:Toggle({Name="Keybind List",Flag="Keybind list",Default=true,Callback=function(v) if KeybindList then KeybindList:SetVisibility(v) end end})
    SS:Toggle({Name="Moderator List",Flag="Moderator list",Default=true,Callback=function(v) if ModeratorList then ModeratorList:SetVisibility(v) end end})
    if not IsMobile then
        SS:Label("Menu Keybind"):Keybind({Name="Menu Keybind",Flag="MenuKeybind",Default=Library.MenuKeybind,Mode="Toggle",Callback=function() Library.MenuKeybind=Library.Flags["MenuKeybind"] and Library.Flags["MenuKeybind"].Key or Library.MenuKeybind end})
    end
    SS:Slider({Name="Tween Speed",Default=0.18,Flag="Tween Speed",Decimals=0.01,Suffix="s",Max=2,Min=0,Callback=function(v) Library.Tween.Time=v end})
    SS:Dropdown({Name="Tween Style",Flag="Tween style",MaxSize=200,Items={"Linear","Quad","Quart","Back","Bounce","Circular","Cubic","Elastic","Exponential","Sine","Quint"},Default="Quart",Callback=function(v) if not v then v="Quart" end; Library.Tween.Style=Enum.EasingStyle[v] end})
    local CS=SP:Section({Name="Configs",Side=side2})
    local configName,configSelected
    local cDropdown=CS:Dropdown({Name="Profiles",Flag="Profiles list",Multi=false,Items={},Callback=function(v) configSelected=v end})
    CS:Textbox({Name="Config name",Default="",Flag="ConfigName",Placeholder="...",Callback=function(v) configName=v end})
    CS:Button({Name="Save",Callback=function()
        if configName and configName~="" then
            pcall(function() writefile(Library.Folders.Configs.."/"..configName..".json",Library:GetConfig()) end)
            Library:RefreshConfigsList(cDropdown); Library:Notification("Saved "..configName,4)
        end
    end})
    CS:Button({Name="Load",Callback=function()
        if configSelected then
            local ok=pcall(function() Library:LoadConfig(readfile(Library.Folders.Configs.."/"..configSelected..".json")) end)
            Library:Notification(ok and "Loaded "..configSelected or "Load failed",4)
        end
    end})
    CS:Button({Name="Delete",Callback=function()
        if configSelected then pcall(function() delfile(Library.Folders.Configs.."/"..configSelected..".json") end); Library:RefreshConfigsList(cDropdown); Library:Notification("Deleted "..configSelected,4) end
    end})
    CS:Button({Name="Refresh",Callback=function() Library:RefreshConfigsList(cDropdown) end})
    pcall(function() Library:RefreshConfigsList(cDropdown) end)
end

