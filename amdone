    local KbDebounce=false; local KbRS
    function Keybind:SetOpen(Bool)
        if KbDebounce then return end; Keybind.IsOpen=Bool; KbDebounce=true
        if Keybind.IsOpen then
            Items["KeybindWindow"].Instance.Size=U2(0,IsMobile and 120 or 90,0,IsMobile and 90 or 72)
            Items["KeybindWindow"].Instance.Visible=true
            Items["KeybindWindow"].Instance.Parent=Library.Holder.Instance
            KbRS=RunService.RenderStepped:Connect(function()
                local bp=Items["KeyButton"].Instance.AbsolutePosition; local bs=Items["KeyButton"].Instance.AbsoluteSize
                if IsMobile then
                    local sc=GetScreenSize(); local ww=Items["KeybindWindow"].Instance.AbsoluteSize.X
                    Items["KeybindWindow"].Instance.Position=U2(0,Clamp(bp.X,10,sc.X-ww-10),0,bp.Y+bs.Y+4)
