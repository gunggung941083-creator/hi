				Keybind.IsOpen = Bool

				Debounce = true

				if Keybind.IsOpen then
					Items["KeybindWindowOutline"].Instance.Visible = true
					Items["KeybindWindowOutline"].Instance.Parent = Library.Holder.Instance

					RenderStepped = RunService.RenderStepped:Connect(function()
