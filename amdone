        Library:Thread(function()
            local n=1
            while Keybind.Picking do
                Items["KeyButton"].Instance.Text=n==1 and "[ . ]" or n==2 and "[ .. ]" or "[ ... ]"
                n=n%3+1; task.wait(0.35)
            end
        end)
        local ib
        ib=UserInputService.InputBegan:Connect(function(Input)
            if Input.UserInputType==Enum.UserInputType.Keyboard then Keybind:Set(Input.KeyCode)
            elseif Input.UserInputType==Enum.UserInputType.Touch then
                Keybind.Picking=false; Items["KeyButton"].Instance.Text="[ Touch ]"
                Keybind.Key="Touch"; Keybind.Value="Touch"
                Library.Flags[Keybind.Flag]={Mode=Keybind.Mode,Key="Touch",Toggled=Keybind.Toggled,active=Keybind.Toggled}
            else Keybind:Set(Input.UserInputType) end
            if ib then ib:Disconnect(); ib=nil end
        end)
    end)
    if IsMobile then MakeLongPress(Items["KeyButton"].Instance,function() Keybind:SetOpen(not Keybind.IsOpen) end)
    else Items["KeyButton"]:Connect("MouseButton2Down",function() Keybind:SetOpen(not Keybind.IsOpen) end) end
    Library:Connect(UserInputService.InputBegan,function(Input)
        if Keybind.Value~="None" and Keybind.Value~="" then
            if tostring(Input.KeyCode)==Keybind.Key or tostring(Input.UserInputType)==Keybind.Key then
                if Keybind.Mode=="Toggle" then Keybind:Press()
                elseif Keybind.Mode=="Hold" then Keybind:Press(true)
                elseif Keybind.Mode=="Always" then Keybind:Press(true) end
            end
        end
        if Input.UserInputType==Enum.UserInputType.MouseButton1 or Input.UserInputType==Enum.UserInputType.Touch then
