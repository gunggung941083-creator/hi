        Colorpicker.Alpha=Clamp((Input.Position.X-ap.X)/as2.X,0,1)
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.08,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(Clamp((Input.Position.X-ap.X)/as2.X,0,0.99),0,0,0)})
        Colorpicker:Update(true)
    end
    function Colorpicker:Update(IsFromAlpha)
        Colorpicker.Color=FromHSV(Colorpicker.Hue,Colorpicker.Saturation,Colorpicker.Value)
        Colorpicker.HexValue=Colorpicker.Color:ToHex()
        Library.Flags[Colorpicker.Flag]={Alpha=Colorpicker.Alpha,Color=Colorpicker.Color,HexValue=Colorpicker.HexValue,Transparency=1-Colorpicker.Alpha}
        Items["ColorpickerButton"]:Tween(nil,{BackgroundColor3=Colorpicker.Color})
        Items["Palette"]:Tween(nil,{BackgroundColor3=FromHSV(Colorpicker.Hue,1,1)})
        Items["HexInput"].Instance.Text="#"..Colorpicker.HexValue
        if not IsFromAlpha then Items["Alpha"]:Tween(nil,{BackgroundColor3=Colorpicker.Color}) end
        if Data.Callback then Library:SafeCall(Data.Callback,Colorpicker.Color,Colorpicker.Alpha) end
    end
    function Colorpicker:Set(Color,Alpha)
        if type(Color)=="table" then Color=FromRGB(Color[1],Color[2],Color[3])
        elseif type(Color)=="string" then pcall(function() Color=FromHex(Color) end) end
        if typeof(Color)~="Color3" then return end
        Colorpicker.Hue,Colorpicker.Saturation,Colorpicker.Value=Color:ToHSV(); Colorpicker.Alpha=Alpha or 0
        Items["PaletteDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(Clamp(1-Colorpicker.Saturation,0,0.99),0,Clamp(1-Colorpicker.Value,0,0.99),0)})
        Items["HueDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(0,0,Clamp(Colorpicker.Hue,0,0.99),0)})
        Items["AlphaDragger"]:Tween(TweenInfo.new(0.1,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Position=U2(Clamp(Colorpicker.Alpha,0,0.99),0,0,0)})
