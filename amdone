    Items["HueInline"]:Connect("InputEnded",function(i) if isSI(i) then SlidingHue=false end end)
    Items["Alpha"]:Connect("InputBegan",function(i) if isSI(i) then SlidingAlpha=true; Colorpicker:SlideAlpha(i) end end)
    Items["Alpha"]:Connect("InputEnded",function(i) if isSI(i) then SlidingAlpha=false end end)
    Items["HexInput"]:Connect("FocusLost",function() Colorpicker:Set(tostring(Items["HexInput"].Instance.Text),Colorpicker.Alpha) end)
    Items["ColorpickerButton"]:Connect("MouseButton1Down",function() Colorpicker:SetOpen(not Colorpicker.IsOpen) end)
    if IsMobile then MakeLongPress(Items["ColorpickerButton"].Instance,function() Colorpicker:SetOpen2(not Colorpicker.IsOpen2) end)
    else Items["ColorpickerButton"]:Connect("MouseButton2Down",function() Colorpicker:SetOpen2(not Colorpicker.IsOpen2) end) end
    Library:Connect(UserInputService.InputChanged,function(Input)
        if not isMV(Input) then return end
        if SlidingPalette then Colorpicker:SlidePalette(Input)
        elseif SlidingHue then Colorpicker:SlideHue(Input)
        elseif SlidingAlpha then Colorpicker:SlideAlpha(Input) end
    end)
    Library:Connect(UserInputService.InputBegan,function(Input)
        if not isSI(Input) then return end
        task.defer(function()
